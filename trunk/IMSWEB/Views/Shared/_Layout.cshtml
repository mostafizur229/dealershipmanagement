<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>Dashboard | AutoRiceMill - Admin Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Auto rice mill dashboard" name="description" />
    <!-- App favicon -->
    <link rel="shortcut icon" href="~/Content/assets/images/favicon.ico">
    @Styles.Render("~/Content/adminCss")
    @Styles.Render("~/Content/dataTableCss")

</head>

<body data-topbar="dark" data-sidebar="dark">

    <!-- Begin page -->
    <div id="layout-wrapper">

        @Html.Partial("_topBar")

        <!-- ========== Left Sidebar Start ========== -->
        @Html.Partial("_sideBar")
        <!-- Left Sidebar End -->
        <!-- ============================================================== -->
        <!-- Start right Content here -->
        <!-- ============================================================== -->
        <div class="main-content">

            <div class="page-content" id="mainContainer">
                <div id="report"></div>
                @RenderBody()
            </div>
            <!-- End Page-content -->


            @Html.Partial("_footer")
        </div>
        <!-- end main content-->

    </div>
    <!-- END layout-wrapper -->
    <!-- Right Sidebar -->
    <!-- /Right-bar -->
    <!-- Right bar overlay-->
    <div class="rightbar-overlay"></div>

    <!-- JAVASCRIPT -->
    @Scripts.Render("~/bundles/adminjs")
    <script src="https://unicons.iconscout.com/release/v2.0.1/script/monochrome/bundle.js"></script>
    @Scripts.Render("~/bundles/adminjs2")
    @Scripts.Render("~/bundles/dataTablejs")
    @RenderSection("scripts", required: false)

<script type="text/javascript">
        $(document).ready(function () {
            //GetClientDateTime();

            //init select2 containing class
            $(".ddl2").select2({
                placeholder: "--- Select ---"
            });

            $('#datatable2').DataTable({
                searching: false,
                paging: false,
                info: false,
            });

        });


        function GetClientDateTime() {
            var ClientDateTime = moment().format('DD MMM YYYY hh:mm:ss a');
            $.ajax({
                url: "/Report/GetClientDateTime/",
                type: "POST",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify({ "ClientDateTime": ClientDateTime }),
                success: function (data) {
                    //console.log(data);
                },
                error: function (data) {
                    //console.log(data);
                }
            });
        }


        $(function () {

            // Selection

            var urlString = window.location.toString();
            var hasValue = urlString.substr(0, urlString.indexOf("/Create"));
            if (hasValue.length < 1) {
                hasValue = urlString.substr(0, urlString.indexOf("/Edit"));
            }
            if (hasValue.length < 1) {
                hasValue = urlString.substr(0, urlString.indexOf("/View"));
            }
            if (hasValue.length < 1) {
                hasValue = urlString.substr(0, urlString.indexOf("/ProfileView"));
            }
            if (hasValue.length < 1) {
                hasValue = urlString.substr(0, urlString.indexOf("?"));
            }
            if (hasValue.length > 0) {
                urlString = hasValue;
            }
            var menuItem = $('#sidebar-menu ul li a').filter(function () {
                return this.href == urlString;
            })

            menuItem.parent('li').addClass('mm-active').parent('ul').addClass('mm-show');
            menuItem.parent('li').parent('ul').prev().addClass('mm-active');
            menuItem.addClass('active');


            //alertify active
            var saveMsg = '@TempData["save"]';
            var updateMsg = '@TempData["update"]';
            var deleteMsg = '@TempData["delete"]';
            var customMsg = '@TempData["custom"]';
            var warningMsg = '@TempData["warning"]';
            var successMsg = '@TempData["success"]';

            if (saveMsg != '') {
                alertify.success('Data saved successfully!');
            }

            if (updateMsg != '') {
                alertify.success('Data updated successfully!');
            }

            if (deleteMsg != '') {
                alertify.success('Data deleted successfully!');
            }

            if (customMsg != '') {
                alertify.error(customMsg);
            }

            if (warningMsg != '') {
                alertify.message(warningMsg);
            }
            if (successMsg != '') {
                alertify.success(successMsg);
            }

            //$.datepicker.setDefaults($.datepicker.regional['en']);

            //$(".datepickerUI").datepicker({
            //    dateFormat: "dd-mm-yy",
            //    changeMonth: false,
            //    changeYear: false,
            //    yearRange: "-90:+2"
            //});

            $(".datepickerUI").datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
            });

        });

    function getDefaultFloatIfEmpty(val) {
        if (val == undefined || val == '' || isNaN(val))
            return 0.0;
        else
            return parseFloat(val);
    }

    function getDefaultIntIfEmpty(val) {
        if (val == undefined || val == '' || isNaN(val))
            return 0;
        else
            return parseInt(val);
    }
</script>

</body>
</html>