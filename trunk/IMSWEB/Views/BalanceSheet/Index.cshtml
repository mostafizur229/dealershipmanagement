                                                    <path d="M3 7v10a1 1 0 0 0 1 1h14" />
                                                </svg>
                                            </div>
                                            <div class="item-info">
                                                <p class="item-name">Total Expense</p>

                                            </div>
                                        </div>
                                        <div class="item-value">৳ @Model.TotalExpense.ToString("N2")</div>
                                    </div>
                                </div>
                                <div class="profit-divider"></div>
                                <div class="net-profit success">
                                    <div class="net-profit-content">
                                        <div class="net-profit-left">
                                            <div class="icon-container success-light">
                                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
                                                    <polyline points="17 6 23 6 23 12" />
                                                </svg>
                                            </div>
                                            <span class="net-profit-label">Total Net Profit</span>
                                        </div>
