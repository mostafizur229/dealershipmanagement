@model IEnumerable<IMSWEB.GetCustomerViewModel>
@using IMSWEB.Model
@{
    ViewBag.Title = "Customers";
}

<style>
    /* DataTables Modern Customization */
    #customerTable thead tr {
        background-color: #3f51b5 !important; /* Theme Color */
        color: white !important;
    }

    #customerTable thead th {
        text-align: center;
        vertical-align: middle;
        border-bottom: none;
    }

    .dataTable td {
        text-align: center;
        vertical-align: middle;
        border-color: #f1f1f1 !important;
    }

    .dt-search .dt-input {
        border-radius: 4px;
        border: 1px solid #ced4da;
        padding: 4px 8px;
    }

    .dt-paging .dt-paging-button.current {
        background: #3f51b5 !important;
        color: white !important;
        border: 1px solid #3f51b5 !important;
        border-radius: 4px;
    }
</style>

<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">@ViewBag.Title</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item active">Manage Existing Customers</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h5 class="header-title">Existing Customers</h5>
                            </div>
                            <div class="col-md-6 text-right">
                                @Html.ActionLink("Create New Customer", "Create", "Customer", null, new { @class = "btn btn-primary btn-sm", @id = "btnCreate" })
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table id="customerTable" class="table table-bordered dt-responsive nowrap table-hover" style="width:100%">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Sl</th>
                                        <th>Code</th>
                                        <th>Name</th>
                                        <th>Contact No</th>
                                        <th>Address</th>
                                        <th>Type</th>
                                        <th>Total Due</th>
                                        <th style="width: 120px;">Actions</th>
                                        <th>Details</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>

    <script>
        // Role Checks (C# 5 compatible)
        var userAdmin = '@User.IsInRole(EnumUserRoles.Admin.ToString())';
        var userLocalAdmin = '@User.IsInRole(EnumUserRoles.LocalAdmin.ToString())';

        $(document).ready(function () {
            $('#customerTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '@Url.Action("GetCustomer", "Customer")',
                    type: 'GET'
                },
                columns: [
                    {
                        data: null,
                        render: function (data, type, row, meta) {
                            return meta.row + 1 + meta.settings._iDisplayStart;
                        }
                    },
                    { data: 'Code' },
                    { data: 'Name' },
                    { data: 'ContactNo' },
                    { data: 'Address' },
                    {
                        data: 'CustomerType',
                        render: function (data) {
                            var types = { 1: 'Retail', 2: 'Dealer', 3: 'Hire', 4: 'Branch(B2B)', 5: 'Both' };
                            return types[data] || 'Unknown';
                        }
                    },
                    {
                        data: 'TotalDue',
                        render: function(data) { return '<b>' + (data || 0) + '</b>'; }
                    },
                    {
                        data: null,
                        render: function (data, type, row) {
                            var isDisabled = (userAdmin === "True" || userLocalAdmin === "True") ? "" : "disabled";
                            return '<div class="btn-group">' +
                                   '<a href="/Customer/Edit/' + row.Id + '" class="btn btn-outline-secondary btn-sm ' + isDisabled + '" title="Edit"><i class="mdi mdi-pencil"></i></a>' +
                                   '<a href="/Customer/Delete/' + row.Id + '" class="btn btn-outline-danger btn-sm ' + isDisabled + '" title="Delete" onclick="return confirm(\'Are you sure?\');"><i class="mdi mdi-delete"></i></a>' +
                                   '</div>';
                        }
                    },
                    {
                        data: null,
                        render: function(data, type, row) {
                            return '<button type="button" class="btn btn-info btn-sm" onclick="showDetails(' + row.Id + ')"><i class="mdi mdi-eye mr-1"></i> Details</button>';
                        }
                    }
                ],
                order: [[1, 'asc']],
                pageLength: 10,
                language: {
                    search: "Search:",
                    paginate: {
                        previous: "<i class='mdi mdi-chevron-left'>",
                        next: "<i class='mdi mdi-chevron-right'>"
                    }
                }
            });
        });

        function showDetails(id) {
            // Your existing detail logic here
            console.log("Showing details for ID: " + id);
        }
    </script>
}