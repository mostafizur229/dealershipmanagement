                                            <p class="item-name">Stock Value</p>
                                        </div>
                                    </div>
                                    <div class="item-value">৳ @Model.StockValue.ToString("N2")</div>
                                </div>

                                <div class="financial-item">
                                    <div class="item-left">
                                        <div class="icon-container emerald-light">
