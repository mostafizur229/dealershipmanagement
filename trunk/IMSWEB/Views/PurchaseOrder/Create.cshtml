@section scripts {
    <!-- CSS and JS Libraries -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/css/bootstrap-datetimepicker.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/js/bootstrap-datetimepicker.min.js"></script>
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            // Prevent Enter key form submission
            $(window).keydown(function (event) {
                if (event.keyCode == 10 || event.keyCode == 13) {
                    event.preventDefault();
                    return false;
                }
            });

            // Date Picker Initialization
            var dateOptions = {
                format: 'DD-MMM-YYYY',
                showTodayButton: true,
                allowInputToggle: true,
                maxDate: moment(),
                icons: {
                    time: 'mdi mdi-clock',
                    date: 'mdi mdi-calendar',
                    up: 'mdi mdi-chevron-up',
                    down: 'mdi mdi-chevron-down',
                    previous: 'mdi mdi-chevron-left',
                    next: 'mdi mdi-chevron-right'
                }
            };

            $('#OrderDateContainer').datetimepicker(dateOptions);

            @if (Model != null && Model.PurchaseOrder.OrderDate != null)
            {
                <text>
                $('#OrderDateContainer').data("DateTimePicker").date('@(Convert.ToDateTime(Model.PurchaseOrder.OrderDate).ToString("dd-MMM-yyyy"))');
                </text>
            }
            else
            {
                <text>
                $('#OrderDateContainer').data("DateTimePicker").date(moment());
                </text>
            }

            // Unit Type logic
            var UnitType = $('#PODetail_UnitType').val();
            var CUnitType = $('#PODetail_TempChildUnitType').val();
            if (UnitType != null && UnitType !== "") {
                if (UnitType.toLowerCase() == "pcs") {
                    $("#divUnitPrice").hide();
                    $("#divChildQuantity").hide();
                } else {
                    $("#lblParentUnit").text($.trim(UnitType));
                    $("#lblChildUnit").text($.trim(CUnitType));
                    $("#divUnitPrice").show();
                    $("#divChildQuantity").show();
                }
            }
        });

        // Ajax Supplier Create
        $("#btnSaveSupplierAjax").click(function () {
            var supplierData = {
                Name: $("#mSupplierName").val(),
                ContactNo: $("#mSupplierContact").val(),
                OpeningDue: $("#mOpeningDue").val() || 0,
                Address: $("#mAddress").val(),
                Remarks: $("#mRemarks").val(),
                IsBoth: $("#mIsBoth").is(":checked") ? 1 : 0
            };

            $.ajax({
                type: "POST",
                url: "/supplier/CreateSupplierAjax",
                data: supplierData,
                success: function (response) {
                    if (response.Result) {
                        toastr.success(response.ErrorMsg);
                        $('#SuppliersModal').modal('hide');

                        var s = response.Supplier;
                        $('#SuppliersId').val(s.Id);
                        $('#SuppliersCode').val(s.Code);
                        $('#SuppliersName').val(s.Name);
                        $('[id*="CurrentDue"]').val(s.TotalDue);
                        $('#dropdownLabel').text(s.Name + " (" + s.Code + ")");

                        if(typeof updateFields === "function") updateFields(s);
                        if(typeof loadSuppliers === "function") loadSuppliers(true);
                        $("#ajaxSupplierForm")[0].reset();
                    } else {
                        toastr.error(response.ErrorMsg);
                    }
                },
                error: function () {
                    toastr.error("Server error occurred.");
                }
            });
        });

        // Damage Return IMEIs Logic
        $('#ProductsModal').on('hidden.bs.modal', function () {
            $("#PODetail_Quantity").trigger("input");
        });

        var _DIMEINo = "";
        $(document).on("click", ".btnGetDamageProduct", function () {
            _DIMEINo = "#DIMEINo" + this.id;
            GetDamageReturnIMEI();
            $('#DamageProductDetailsModal').modal('toggle');
        });

        function GetDamageReturnIMEI() {
            var ProducctID = $("#ProductsId").val();
            if (ProducctID == "" || ProducctID == undefined) {
                toastr.info("Please Select Product.");
                return;
            }
            var ColorID = $("#PODetail_ColorId").val();
            if (ColorID == "" || ColorID == undefined) {
                toastr.info("Please Select Color.");
                return;
            }
            $.ajax({
                url: "/PurchaseOrder/GetDamageReturnIMEI",
                type: "GET",
                data: { "ProductID": ProducctID, "ColorID": ColorID },
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (data) {
                    if (data.Status == true) {
                        PopulateDamageProductDetailsTable(data);
                    }
                },
                error: function (err) {
                    console.log(err);
                }
            });
        }

        function PopulateDamageProductDetailsTable(data) {
            var $table = $("#DamageProductDetailsTable >tbody");
            $table.empty();
            var counter = 1;
            data.Data.forEach(function (item) {
                var $row = $('<tr/>');
                $row.append('<td><input type="checkbox" class="chkbxProduct" name="chkbxProduct" value="' + item.IMENO + '"/></td><td>' + counter + '</td><td>' + item.ProductCode + '</td><td>' + item.ProductName + '</td><td>' + item.CategoryName + '</td><td>' + item.CompanyName + '</td><td>' + item.ColorName + '</td><td>' + item.IMENO + '</td>');
                $table.append($row);
                counter++;
            });
        }

        $(document).on('change', 'input.chkbxProduct', function () {
            $('input.chkbxProduct').not(this).prop('checked', false);
            if(this.value) {
                $(_DIMEINo).val(this.value);
            } else {
                $(_DIMEINo).val("");
            }
            checkDuplicateDIMEINo();
            $('#DamageProductDetailsModal').modal('toggle');
        });

        $("#PurchaseOrder_IsDamagePO").on("change", function () {
            $(".btnGetDamageProduct").prop("disabled", !this.checked);
        });

        // Quantity Input Event & Row Generation
        $("#PODetail_Quantity").on("input", function () {
            var purchaseRate = $("#PODetail_UnitPrice").val();
            var TAmount = (parseInt($(this).val()) * parseFloat(purchaseRate));
            $("#PODetail_TAmount").val(TAmount);

            var productName = $('#ProductsName').val();
            if (productName == '') {
                toastr['error']('Please pick a product first.');
                return;
            }

            var ProductType = $('#ProductsType').val();
            var Quantity = $("#PODetail_Quantity").val();
            $("#productIdentifierTable > tbody > tr.no-records-found").html('');
            if (ProductType == "1" || ProductType == "3")
                createProductIdentifierTableRows(Quantity);
            else if (ProductType == "2") {
                createProductIdentifierTableRows(1);
                $("#IMEINo1").val("No Barcode");
            }
        });

        function createProductIdentifierTableRows(quantity) {
            var counterLimit = parseInt(quantity);
            var preCount = 0;
            var productName = $('#ProductsName').val();
            var newRow = '';
            var cols = '';
            var ProductType = parseInt($('#ProductsType').val());

            $("#productIdentifierTable tr").each(function (count, row) {
                var $row = $(row);
                if (!$row) return;
                var $inputs = $row.find('input[name^="IMEINo"]');
                if (!$inputs) return;
                if (ProductType == 1 || ProductType == 2) {
                    $inputs.each(function (count, input) {
                        var val = $(input).val();
                        if (val == '' || val == "No Barcode") {
                            $(this).parents('tr').remove();
                        } else {
                            preCount = parseInt($(this).parent().siblings(":first").text());
                        }
                    });
                } else {
                    $inputs.each(function (count, input) {
                        $(this).parents('tr').remove();
                    });
                }
            });

            var IsDamage = $("#PurchaseOrder_IsDamagePO").prop("checked") == true;

            if (ProductType == 1 || ProductType == 2) {
                for (var counter = (preCount + 1) ; counter <= counterLimit; counter++) {
                    newRow = $("<tr>");
                    cols = "";
                    cols += '<td width="5%">' + counter + '</td>';
                    cols += '<td width="26.84%">' + productName + '</td>';
                    cols += '<td width="30%"><input type="text" class="form-control input-sm" onblur="checkDuplicateIMEINo()" oninput="moveCursorToNextInput(this)" name="IMEINo' + counter + '" id="IMEINo' + counter + '"/></td>';
                    cols += '<td width="50%"><input type="text" readonly class="form-control input-sm" onblur="checkDuplicateDIMEINo()" oninput="moveCursorToNextInputForDamage(this)" name="DIMEINo' + counter + '" id="DIMEINo' + counter + '"/></td>';
                    cols += '<td width="20%"><button type="button" id=' + counter + ' class="btn btn-xs btn-info btnGetDamageProduct" title="Get Damage Product" ' + (IsDamage ? '' : 'disabled') + '><i class="mdi mdi-information-outline"></i></button></td>';
                    newRow.append(cols);
                    $("#productIdentifierTable").append(newRow);
                }
            } else if (ProductType == 3) {
                $.ajax({
                    url: "/PurchaseOrder/GetUniqueBarCode",
                    type: "GET",
                    data: { 'MaxSize': 7, 'Quantity': quantity },
                    dataType: "json",
                    success: function (data) {
                        for (var counter = (preCount + 1) ; counter <= counterLimit; counter++) {
                            newRow = $("<tr>");
                            cols = "";
                            cols += '<td width="9.97%">' + counter + '</td>';
                            cols += '<td width="26.84%">' + productName + '</td>';
                            cols += '<td width="63.18%"><input type="text" class="form-control input-sm" name="IMEINo' + counter + '" id="IMEINo' + counter + '" value="' + data[counter - 1] + '" /></td>';
                            cols += '<td width="50%"><input type="text" ' + (IsDamage ? '' : 'readonly') + ' class="form-control input-sm" onblur="checkDuplicateDIMEINo()" oninput="moveCursorToNextInputForDamage(this)" name="DIMEINo' + counter + '" id="DIMEINo' + counter + '"/></td>';
                            newRow.append(cols);
                            $("#productIdentifierTable").append(newRow);
                        }
                    }
                });
            }
        }

        function moveCursorToNextInput(x) {
            if (!x.value) return;
            @if(User.Identity.IsAuthenticated && (User.Identity.Name == "5" || User.Identity.Name == "6" || User.Identity.Name == "1")) { <text> return; </text> }
            setTimeout(function () {
                var $inputs = $(x).parents('tr').next('tr').find('input[name^="IMEINo"]');
                $inputs.each(function (count, input) { $(input).focus(); });
            }, 500);
        }

        function moveCursorToNextInputForDamage(x) {
            if (!x.value) return;
            @if(User.Identity.IsAuthenticated && (User.Identity.Name == "5" || User.Identity.Name == "6" || User.Identity.Name == "1")) { <text> return; </text> }
            setTimeout(function () {
                var $inputs = $(x).parents('tr').next('tr').find('input[name^="DIMEINo"]');
                $inputs.each(function (count, input) { $(input).focus(); });
            }, 500);
        }

        function checkDuplicateIMEINo() {
            var previousVal = '';
            var $inputs = $('#productIdentifierTable').find('input[name^="IMEINo"]');
            $inputs.each(function (count, input) {
                if ($(input).val() != '' && $(input).val().toLowerCase() == previousVal.toLowerCase()) {
                    toastr['error']('Duplicate IMEI/Barcode found');
                    $(input).val('').focus();
                    return false;
                }
                previousVal = $(input).val();
            });
        }

        function checkDuplicateDIMEINo() {
            var previousVal = '';
            var $inputs = $('#productIdentifierTable').find('input[name^="DIMEINo"]');
            $inputs.each(function (count, input) {
                if ($(input).val() != '' && $(input).val().toLowerCase() == previousVal.toLowerCase()) {
                    toastr['error']('Duplicate IMEI/Barcode found');
                    $(input).val('').focus();
                    return false;
                }
                previousVal = $(input).val();
            });
        }

        // Price Calculations Core Logic
        function getDefaultFloatIfEmpty(val) { return parseFloat(val) || 0; }

        $("#PODetail_MRPRateParent").on("input", function () {
            var ConvertValue = getDefaultFloatIfEmpty($("#PODetail_ConvertValue").val());
            if (ConvertValue != 0) {
                var mrpRateParent = getDefaultFloatIfEmpty($(this).val());
                $("#PODetail_MRPRate").val(mrpRateParent / ConvertValue).trigger('input');
            }
        });

        $("#PODetail_MRPRate").on("input", function () {
            var quantity = getDefaultFloatIfEmpty($("#PODetail_Quantity").val());
            var mrpRate = getDefaultFloatIfEmpty($(this).val());
            var total = (quantity * mrpRate);

            var percentage = getDefaultFloatIfEmpty($("#PODetail_PPDisPercentage").val());
            var PPDamount = ((mrpRate * percentage) / 100);
            total -= (PPDamount * quantity);
            var UnitPrice = (mrpRate - PPDamount);

            var ExPercentage = getDefaultFloatIfEmpty($("#PODetail_ExtraPPDISPer").val());
            var ExPPDamount = ((UnitPrice * ExPercentage) / 100);
            total -= (ExPPDamount * quantity);
            UnitPrice = (UnitPrice - ExPPDamount);

            var PPOffer = getDefaultFloatIfEmpty($("#PODetail_PPOffer").val());
            UnitPrice -= PPOffer;
            total -= (PPOffer * quantity);

            $("#PODetail_TAmount").val(getDefaultFloatIfEmpty(total));
            $("#PODetail_PPDiscountAmount").val(PPDamount);
            $("#PODetail_ExtraPPDISAmt").val(ExPPDamount);
            $("#PODetail_UnitPrice").val(UnitPrice);
            $("#PODetail_CRSalesRate3Month").val(mrpRate);
        });

        $("#PODetail_PPDisPercentage").on("input", function () {
            var percentage = getDefaultFloatIfEmpty($(this).val());
            var quantity = getDefaultFloatIfEmpty($("#PODetail_Quantity").val());
            var mrpRate = getDefaultFloatIfEmpty($("#PODetail_MRPRate").val());

            var PPDamount = ((mrpRate * percentage) / 100);
            $("#PODetail_PPDiscountAmount").val(PPDamount);
            var UnitPrice = mrpRate - PPDamount;
            var total = (quantity * mrpRate) - (PPDamount * quantity);

            var ExPercentage = getDefaultFloatIfEmpty($("#PODetail_ExtraPPDISPer").val());
            var ExPPDamount = ((UnitPrice * ExPercentage) / 100);
            total -= (ExPPDamount * quantity);
            UnitPrice -= ExPPDamount;

            var PPOffer = getDefaultFloatIfEmpty($("#PODetail_PPOffer").val());
            UnitPrice -= PPOffer;
            total -= (PPOffer * quantity);

            $("#PODetail_ExtraPPDISAmt").val(ExPPDamount);
            $("#PODetail_UnitPrice").val(UnitPrice);
            $("#PODetail_TAmount").val(getDefaultFloatIfEmpty(total));
        });

        $("#PODetail_PPDiscountAmount").on("input", function () {
            var PPDamount = getDefaultFloatIfEmpty($(this).val());
            var quantity = getDefaultFloatIfEmpty($("#PODetail_Quantity").val());
            var mrpRate = getDefaultFloatIfEmpty($("#PODetail_MRPRate").val());

            var percentage = getDefaultFloatIfEmpty(((100 * PPDamount) / (quantity * mrpRate)) * quantity);
            $("#PODetail_PPDisPercentage").val(percentage);
            var UnitPrice = mrpRate - PPDamount;
            var total = (quantity * mrpRate) - (PPDamount * quantity);

            var PPOffer = getDefaultFloatIfEmpty($("#PODetail_PPOffer").val());
            UnitPrice -= PPOffer;
            total -= (PPOffer * quantity);

            var ExPercentage = getDefaultFloatIfEmpty($("#PODetail_ExtraPPDISPer").val());
            var ExPPDamount = ((UnitPrice * ExPercentage) / 100);
            total -= (ExPPDamount * quantity);
            UnitPrice -= ExPPDamount;

            $("#PODetail_ExtraPPDISAmt").val(ExPPDamount);
            $("#PODetail_UnitPrice").val(UnitPrice);
            $("#PODetail_TAmount").val(getDefaultFloatIfEmpty(total));
        });

        // Event triggers for quantities
        $("#PODetail_ParentQuantity, #PODetail_ChildQuantity").on('input', function () {
            var ConvertValue = getDefaultFloatIfEmpty($("#PODetail_ConvertValue").val());
            var ChildQty = getDefaultFloatIfEmpty($("#PODetail_ChildQuantity").val());
            var ParentQty = getDefaultFloatIfEmpty($("#PODetail_ParentQuantity").val());
            var TotalQty = parseFloat((ConvertValue * ParentQty) + ChildQty);
            $("#PODetail_Quantity").val(TotalQty).trigger('input');

            // Recalculate Area & Total
            var SizeName = $("#PODetail_SizeName").val() || "0x0";
            var spSize = SizeName.split('x');
            if ($('#CategoryName').val() == "Tiles") {
                var AreaPerCarton = $("#PODetail_AreaPerCarton").val();
                var SqFtPerPcs = parseFloat(AreaPerCarton / ConvertValue);
                var TotalAreaSqft = parseFloat((SqFtPerPcs * TotalQty));
                $("#PODetail_TotalArea").val(TotalAreaSqft);
                var RatePerSqFt = getDefaultFloatIfEmpty($("#PODetail_RatePerArea").val());
                $("#PODetail_MRPRate").val(SqFtPerPcs * RatePerSqFt).trigger('input');
            }

            var unitPrice = getDefaultFloatIfEmpty($('#PODetail_MRPRateParent').val());
            var tAmount = ((unitPrice / (ConvertValue || 1)) * TotalQty).toFixed(3);
            $('#PODetail_TAmount').val(getDefaultFloatIfEmpty(tAmount));
        });

        // Payment Flat discount logic
        $("#PurchaseOrder_TotalDiscountPercentage").on("input", function () {
            var totalPercentage = getDefaultFloatIfEmpty($(this).val());
            var totalAmount = getDefaultFloatIfEmpty($("#PurchaseOrder_GrandTotal").val());
            var totalDiscountAmount = getDefaultFloatIfEmpty((totalAmount * totalPercentage) / 100).toFixed(2);
            $("#PurchaseOrder_TotalDiscountAmount").val(totalDiscountAmount);
            calculateVariousValue(totalDiscountAmount, totalAmount);
        });

        $("#PurchaseOrder_TotalDiscountAmount").on("input", function () {
            var totalDiscountAmount = getDefaultFloatIfEmpty($(this).val());
            var totalAmount = getDefaultFloatIfEmpty($("#PurchaseOrder_GrandTotal").val());
            var totalPercentage = getDefaultFloatIfEmpty((100 * totalDiscountAmount) / totalAmount).toFixed(2);
            $("#PurchaseOrder_TotalDiscountPercentage").val(totalPercentage);
            calculateVariousValue(totalDiscountAmount, totalAmount);
        });

        $("#PurchaseOrder_LabourCost, #PurchaseOrder_RecieveAmount, #PurchaseOrder_AdjAmount").on("input", function () {
            calculateVariousValue(getDefaultFloatIfEmpty($("#PurchaseOrder_TotalDiscountAmount").val()), getDefaultFloatIfEmpty($("#PurchaseOrder_GrandTotal").val()));
        });

        function calculateVariousValue(flatDiscountAmt, grandtotalAmount) {
            var resultFromSysinfo = '@ViewBag.IsLabourCostDeduct';
            var tempFlatDisAmt = getDefaultFloatIfEmpty($("#PurchaseOrder_tempFlatDiscountAmount").val());
            var tempNetDisAmt = getDefaultFloatIfEmpty($("#PurchaseOrder_tempNetDiscount").val());
            var updatedflatDiscountAmount = parseFloat(flatDiscountAmt) - tempFlatDisAmt;
            var labourCost = getDefaultFloatIfEmpty($("#PurchaseOrder_LabourCost").val());
            var recieveAmount = getDefaultFloatIfEmpty($("#PurchaseOrder_RecieveAmount").val());
            var adjAmount = getDefaultFloatIfEmpty($("#PurchaseOrder_AdjAmount").val());
            var updateNetDisAmt = tempNetDisAmt + updatedflatDiscountAmount;

            $("#PurchaseOrder_NetDiscount").val(updateNetDisAmt.toFixed(2));

            if (resultFromSysinfo === "True") {
                $("#PurchaseOrder_TotalAmount").val((grandtotalAmount - (updateNetDisAmt + adjAmount) - labourCost).toFixed(2));
                $("#PurchaseOrder_PaymentDue").val((grandtotalAmount - (updateNetDisAmt + adjAmount) - labourCost - recieveAmount).toFixed(2));
            } else {
                $("#PurchaseOrder_TotalAmount").val((grandtotalAmount - (updateNetDisAmt + adjAmount) + labourCost).toFixed(2));
                $("#PurchaseOrder_PaymentDue").val((grandtotalAmount - (updateNetDisAmt + adjAmount) + labourCost - recieveAmount).toFixed(2));
            }
        }

        // Product Modal Save Action
        $("#btnNewSaveProduct").click(function () {
            var productData = {
                ProductName: $("#ProductName").val(),
                CompanyId: $("#CompanyId").val(),
                CategoryId: $("#CategoryId").val(),
                SizeID: $("#SizeID").val(),
                SizeName: $("#SizeName").val(),
                CompanyName: $("#CompanyName").val(),
                CategoryName: $("#CategoryName").val(),
                IDCode: $("#IDCode").val(),
                UnitType: $("#UnitType").val(),
                RP: $("#mRP").val() || 0,
                MRP: $("#mMRP").val() || 0,
                LimitedStkQty: $("#mLimitedStkQty").val() || 0,
                ProductType: $("#ProductType").val(),
                BundleQty: 0,
                ServiceWarrentyMonth: "0 Month(s)",
                SparePartsWarrentyMonth: "0 Month(s)"
            };

            if (!productData.ProductName || !productData.CompanyId || !productData.CategoryId || !productData.UnitType) {
                toastr.warning("Please fill Name, Company, Category and Unit.");
                return;
            }

            $.ajax({
                type: "POST",
                url: "/product/AddProduct",
                data: productData,
                success: function (response) {
                    if (response.result) {
                        toastr.success(response.msg);
                        var p = response.data;
                        $('#ProductsId').val(p.ProductID);
                        $('#ProductsCode').val(p.Code);
                        $('#ProductsName').val(p.ProductName);
                        $('#ProductsType').val(p.ProductType);
                        $('#PODetail_MRPRateParent').val(p.RP).trigger("input");
                        $('#PODetail_SalesRate').val(p.MRP).trigger("input");

                        if (typeof loadProducts === "function") loadProducts(true);
                        $('#newProductAddModal').modal('hide');
                    } else {
                        toastr.error(response.msg);
                    }
                },
                error: function () {
                    toastr.error("An error occurred while saving the product.");
                }
            });
        });
    </script>
}