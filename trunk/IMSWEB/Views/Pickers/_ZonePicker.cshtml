@model dynamic

<!-- ========================= -->
<!-- Zone Picker -->
<!-- ========================= -->
<div class="row">
    <div class="col-md-12">
        <label class="font-weight-bold mb-2 text-muted">
            Select Zone
        </label>
        <div class="input-group">
            <!-- Zone Code -->
            <input type="text"
                   id="ZonesCode"
                   name="ZonesCode"
                   class="form-control form-control-sm bg-light"
                   value="@ViewBag.ZonesCode"
                   placeholder="Zone Code"
                   readonly />

            <!-- Picker Button -->
            <div class="input-group-append">
                <button type="button"
                        class="btn btn-info btn-sm px-3 waves-effect waves-light"
                        data-toggle="modal"
                        data-target="#ZonesModal"
                        tabindex="-1">
                    <i class="mdi mdi-map-marker-search"></i> Pick
                </button>
            </div>

            <!-- Zone Name -->
            <input type="text"
                   id="ZonesName"
                   name="ZonesName"
                   class="form-control form-control-sm bg-light"
                   value="@ViewBag.ZonesName"
                   placeholder="Zone Name"
                   readonly />

            <!-- Hidden Id -->
            <input type="hidden"
                   id="ZonesId"
                   name="ZonesId"
                   value="@ViewBag.ZonesId" />
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- Zone Modal -->
<!-- ========================= -->
<div class="modal fade" id="ZonesModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title text-white">
                    <i class="mdi mdi-map-marker-radius mr-1"></i>
                    Select Zone
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <!-- Body -->
            <div class="modal-body p-3">
                <!-- Search & Action Section -->
                <div class="row mb-3">
                    <div class="col-md-8">
                        <div class="input-group input-group-sm">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light border-right-0">
                                    <i class="mdi mdi-magnify"></i>
                                </span>
                            </div>
                            <input type="text"
                                   id="zoneSearch"
                                   class="form-control border-left-0"
                                   placeholder="Search zone by code or name..." />
                        </div>
                    </div>
                    <div class="col-md-4 text-right">
                        @Html.ActionLink("Create New Zone", "Create", "Zone", null, new { @class = "btn btn-primary btn-sm", target = "_blank" })
                    </div>
                </div>

                <!-- Table Section -->
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0" id="ZonesTable">
                        <thead class="thead-light">
                            <tr>
                                <th width="60" class="text-center">SL</th>
                                <th width="150">Code</th>
                                <th>Zone Name</th>
                                <th width="100" class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int count = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center text-muted">@count</td>
                                        <td class="font-weight-bold text-primary">@item.Code</td>
                                        <td>@item.Name</td>
                                        <td class="text-center">
                                            <button type="button"
                                                    class="btn btn-success btn-sm select-zone waves-effect waves-light"
                                                    data-id="@item.Id"
                                                    data-code="@item.Code"
                                                    data-name="@item.Name">
                                                <i class="mdi mdi-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    count++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer bg-light">
                <span class="mr-auto text-muted small">
                    <i class="mdi mdi-information-outline mr-1"></i>
                    Pick a zone to auto-fill the form
                </span>
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            // ====================================
            // Select Zone Logic
            // ====================================
            $(document).on('click', '.select-zone', function () {
                var id = $(this).data('id');
                var code = $(this).data('code');
                var name = $(this).data('name');

                // Set values to parent input fields
                $('#ZonesId').val($.trim(id));
                $('#ZonesCode').val($.trim(code));
                $('#ZonesName').val($.trim(name));

                // Hide the modal
                $('#ZonesModal').modal('hide');
            });

            // ====================================
            // Client-Side Search Logic
            // ====================================
            $(document).on('keyup', '#zoneSearch', function () {
                var value = $(this).val().toLowerCase();
                $('#ZonesTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}