@using IMSWEB.Model
@model IMSWEB.CreateCashCollectionViewModel

@{
    ViewBag.Title = "Cash Collection Report";
}

<h4 class="inline-header">@ViewBag.Title.</h4>
<hr />

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8 col-sm-12">
        <div class="panel panel-default">
            <div class="panel-body">
                @using (Ajax.BeginForm("CashCollectionReport", "Report", new { ReturnUrl = ViewBag.ReturnUrl },
                    ajaxOptions: new AjaxOptions { HttpMethod = "Post", UpdateTargetId = "report", LoadingElementId = "spinningIcon" },
                    htmlAttributes: new { role = "form" }))
                {
                    <div class="form-group row">
                        <label class="col-sm-4 col-form-label">Customer Name</label>
                        <div class="col-sm-8">
                            @{ Html.RenderAction("RenderPicker", "Picker", new { pickerType = PickerType.Customer, id = (Model != null && Model.CustomerID != null) ? Model.CustomerID : "0" }); }
                            @Html.ValidationMessageFor(model => model.CustomerID, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-sm-4 col-form-label">From Date</label>
                        <div class="col-sm-8">
                            <div class="input-group date" id="FromDate">
                                <input type="text" class="form-control input-sm" name="FromDate" />
                                <span class="input-group-addon">
                                    <i class="fa fa-calendar" aria-hidden="true"></i>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-sm-4 col-form-label">To Date</label>
                        <div class="col-sm-8">
                            <div class="input-group date" id="ToDate">
                                <input type="text" class="form-control input-sm" name="ToDate" />
                                <span class="input-group-addon">
                                    <i class="fa fa-calendar" aria-hidden="true"></i>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-sm-4 col-form-label">Report Type</label>
                        <div class="col-sm-8">
                            <select class="form-control input-sm" name="ReportType" id="rdoAll">
                                <option value="0" selected>All</option>
                                <option value="1">Cash Sales</option>
                                <option value="2">Cash Collection</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group row align-items-center">
                        <div class="col-sm-4">
                            <img id="spinningIcon" height="45" width="45" style="display: none;" class="pull-right" src="~/Content/images/Spinner.gif" />
                        </div>
                        <div class="col-sm-8">
                            <input id="btnPreview" type="submit" value="Preview" class="btn btn-sm btn-info" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    $('#FromDate').datetimepicker({
        defaultDate: moment(),
        format: 'DD-MMM-YYYY'
    });

    $('#ToDate').datetimepicker({
        defaultDate: moment(),
        format: 'DD-MMM-YYYY'
    });

    //$('form').submit(function () {
    //    var customerId = $.trim($('#CustomerId').val());
    //    alert(customerId);
    //    if (customerId === '') {
    //        toastr.error("Please select a customer.");
    //        return false;
    //    }
    //});
</script>
