<!--<script src="https://cdnjs.cloudflare.com/ajax/libs/apexcharts/3.48.0/apexcharts.min.js"></script>

<script>
    $(document).ready(function () {
        // ১. উইজেট ডেটা লোড করা
        GetDailySalesAmt();

        // ২. চার্ট লোড করা
        fetchAndRenderCharts();

        // ৩. লো স্টক চেক (পেজ লোড হওয়ার সাথে সাথে)
        loadLimitedStockProducts();
    });

    // উইজেট ডেটা ফেচিং ফাংশন
    function GetDailySalesAmt() {
        $.ajax({
            url: "@Url.Action("GetDailySalesAmt", "Home")",
            type: "GET",
            data: { dataLength: "d7" },
            success: function (widgets) {
                if (widgets && widgets.length > 0) {
                    $.each(widgets, function (index, element) {
                        var amount = (element.Amount != null) ? element.Amount.toLocaleString('en-US', {minimumFractionDigits: 2}) : "0.00";

                        if (element.TrType === "SalesAmount") $("#dailySalesAmt").text(amount);
                        else if (element.TrType === "PurchaseAmount") $("#dailyPurchaseAmt").text(amount);
                        else if (element.TrType === "Expense") $("#txtExpense").text(amount);
                        else if (element.TrType === "CashCollection") $("#txtCashCollection").text(amount);
                    });
                }
            },
            error: function (err) { console.error("Widget Load Error:", err); }
        });
    }

    // চার্ট ডেটা ফেচিং ফাংশন
    function fetchAndRenderCharts() {
        $.ajax({
            url: '/Home/GetYearlyData',
            type: 'GET',
            data: { dataLength: '365' },
            success: function (response) {
                var salesData = new Array(12).fill(0), expenseData = new Array(12).fill(0), incomeData = new Array(12).fill(0);

                response.forEach(function (item) {
                    if (item.TrType === 'SalesAmount') salesData[item.Month - 1] = item.Amount;
                    else if (item.TrType === 'Income') incomeData[item.Month - 1] = item.Amount;
                    else if (item.TrType === 'Expense') expenseData[item.Month - 1] = item.Amount;
                });

                // বার চার্ট রেন্ডার
                new ApexCharts(document.querySelector("#barchart"), {
                    series: [{ name: 'Sales', data: salesData }],
                    chart: { height: 350, type: 'bar', toolbar: { show: false } },
                    colors: ['#764ba2'],
                    plotOptions: { bar: { borderRadius: 4, columnWidth: '45%' } },
                    xaxis: { categories: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"] }
                }).render();

                // এরিয়া চার্ট রেন্ডার
                new ApexCharts(document.querySelector("#areachart"), {
                    series: [{ name: 'Expense', data: expenseData }, { name: 'Income', data: incomeData }],
                    chart: { height: 350, type: 'area', toolbar: { show: false } },
                    colors: ['#f5576c', '#43e97b'],
                    stroke: { curve: 'smooth', width: 2 },
                    xaxis: { categories: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"] }
                }).render();
            }
        });
    }

    // লো স্টক প্রোডাক্ট লোড
    function loadLimitedStockProducts() {
        $.ajax({
            url: '/Home/GetLimitedStockProducts',
            type: 'GET',
            success: function (response) {
                $("#productTable tbody").empty();
                $.each(response, function (index, product) {
                    let row = `<tr>
                        <td>${index + 1}</td>
                        <td>${product.ProductName}</td>
                        <td>${product.CompanyName}</td>
                        <td>${product.SizeName}</td>
                        <td><span class="badge badge-soft-danger">${product.Quantity}</span></td>
                    </tr>`;
                    $("#productTable tbody").append(row);
                });
            }
        });
    }
</script>-->