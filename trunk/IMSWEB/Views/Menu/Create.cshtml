@model IMSWEB.MenuViewModel
@{
    string actionName = ViewContext.RouteData.Values["action"].ToString();
    ViewBag.Title = actionName + " Menu";
}

<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">@ViewBag.Title</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Menu")">Menu</a></li>
                    <li class="breadcrumb-item active">@actionName</li>
                </ol>
            </div>
            <div class="col-md-4 text-right">
                <a href="@Url.Action("Index", "Menu")" class="btn btn-sm btn-secondary waves-effect">
                    <i class="mdi mdi-arrow-left mr-1"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <h5 class="header-title mb-4">Menu Information</h5>

                @using (Html.BeginForm(actionName, "Menu", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form", autocomplete = "off" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="row">
                        @* Left Column *@
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                @Html.LabelFor(model => model.Title, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter menu title" } })
                                @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group mb-3">
                                @Html.LabelFor(model => model.ParentId, "Parent Menu", new { @class = "form-label" })
                                @Html.DropDownListFor(model => model.ParentId, Model.Menus, "-- Select a parent menu --", new { @class = "form-control select2" })
                                @Html.ValidationMessageFor(model => model.ParentId, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group mb-3">
                                @Html.LabelFor(model => model.Url, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Url, new { htmlAttributes = new { @class = "form-control", placeholder = "Controller/Action" } })
                                @Html.ValidationMessageFor(model => model.Url, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group mb-3">
                                @Html.LabelFor(model => model.Icon, new { @class = "form-label" })
                                <div class="input-group">
                                    @Html.EditorFor(model => model.Icon, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g. fa fa-home" } })
                                    <div class="input-group-append">
                                        <a href="https://fontawesome.com/v4.7.0/icons/" class="btn btn-info" target="_blank" title="Find Icon">
                                            <i class="mdi mdi-magnify"></i>
                                        </a>
                                    </div>
                                </div>
                                <small class="text-muted">Copy the full 'i' tag or class name from FontAwesome.</small>
                                @Html.ValidationMessageFor(model => model.Icon, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        @* Right Column *@
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                @Html.LabelFor(model => model.Description, new { @class = "form-label" })
                                @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = "4", placeholder = "Optional description..." })
                                @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group mb-3">
                                @Html.LabelFor(model => model.Sequence, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Sequence, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                                @Html.ValidationMessageFor(model => model.Sequence, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group mb-4 mt-4">
                                <div class="custom-control custom-checkbox">
                                    @Html.CheckBoxFor(model => model.WithoutView, new { @class = "custom-control-input", id = "customCheck1" })
                                    <label class="custom-control-label" for="customCheck1">@Html.DisplayNameFor(model => model.WithoutView)</label>
                                </div>
                                @Html.ValidationMessageFor(model => model.WithoutView, "", new { @class = "text-danger" })
                            </div>

                            <div class="text-right">
                                <button type="submit" class="btn btn-primary waves-effect waves-light px-4">
                                    <i class="mdi mdi-content-save mr-1"></i> @(actionName == "Create" ? "Add Menu" : "Update Menu")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
    @* Select2 CSS and JS if needed *@
    <script>
        $(function () {
            $(".select2").select2({
                width: '100%'
            });
        });
    </script>
}