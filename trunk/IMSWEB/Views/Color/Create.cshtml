@model IMSWEB.CreateColorViewModel
@{
    string actionName = ViewContext.RouteData.Values["action"].ToString();
    ViewBag.Title = actionName + " Color";
}

<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">@ViewBag.Title</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Color")">Grade List</a></li>
                    <li class="breadcrumb-item active">@actionName</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <div class="card">
                    <div class="card-body">
                        <h5 class="header-title mb-4">Color Information</h5>

                        @using (Html.BeginForm(actionName, "Color", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.Id)

                            <div class="form-group row mb-3">
                                @Html.LabelFor(model => model.Code, htmlAttributes: new { @class = "col-md-3 col-form-label-sm" })
                                <div class="col-md-9">

                                    @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control form-control-sm", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.Code, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "col-md-3 col-form-label-sm" })
                                <div class="col-md-9">
                                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control form-control-sm", autofocus = "autofocus", placeholder = "Enter grade name" } })
                                    @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <hr />

                            <div class="form-group row mb-0">
                                <div class="col-md-9 offset-md-3">

                                    <button type="submit" class="btn btn-primary btn-sm waves-effect waves-light" style="min-width: 80px;">
                                        <i class="mdi mdi-check-circle mr-1"></i> @(actionName == "Create" ? "Save" : "Update")
                                    </button>
                                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm waves-effect ml-1">
                                        Cancel
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>