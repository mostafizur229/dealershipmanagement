<div class="vertical-menu">

    <div data-simplebar class="h-100">

        <div id="sidebar-menu">

            @Html.Raw(Html.BuildMenuNavigation())

        </div>

    </div>

</div>


<style>

    .vertical-menu {
        width: 260px;
        background: #1f2a36;
        box-shadow: 0 0 30px rgba(0,0,0,0.08);
    }

    #sidebar-menu {
        padding: 10px 0;
    }

    .side-menu {
        padding-top: 10px;
    }

    .menu-title {
        font-size: 11px !important;
        font-weight: 600 !important;
        padding: 22px 24px 12px 24px !important;
        color: rgba(255,255,255,0.45) !important;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .side-menu li {
        margin: 2px 0;
    }

        .side-menu li a {
            display: flex !important;
            align-items: center !important;
            gap: 12px;
            padding: 12px 20px !important;
            margin: 2px 10px;
            border-radius: 6px;
            color: #a8b4c1 !important;
            font-size: 15px !important;
            font-weight: 500;
            transition: all .3s ease;
            text-decoration: none !important;
            position: relative;
        }

            .side-menu li a:hover {
                background: rgba(255,255,255,0.06);
                color: #ffffff !important;
            }

            .side-menu li a i {
                font-size: 18px !important;
                min-width: 20px;
            }

    .side-menu .menu-text-large {
        font-size: 15px !important;
        font-weight: 500;
        margin-left: 0 !important;
        color: inherit;
    }

    .active-menu {
        color: #ffffff !important;
        background: linear-gradient(90deg, rgba(114,124,245,.30), transparent);
        border-left: 3px solid #727cf5;
    }

        .active-menu .menu-text-large {
            color: #ffffff !important;
            font-weight: 600;
        }

    .sub-menu {
        padding-left: 0 !important;
        margin-top: 3px;
    }

        .sub-menu li {
            list-style: none;
        }

            .sub-menu li a {
                padding: 10px 20px 10px 52px !important;
                font-size: 14px !important;
                color: #8fa2b7 !important;
            }

                .sub-menu li a:hover {
                    color: #ffffff !important;
                    background: rgba(255,255,255,0.04);
                }

    .has-arrow:after {
        position: absolute;
        right: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #8391a2;
    }
</style>