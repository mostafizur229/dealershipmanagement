@model IEnumerable<IMSWEB.CreateUserViewModel>
@{
    ViewBag.Title = "Users";
    int count = 1;
}

<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">Users</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item active">Manage Existing Application Users</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h5 class="header-title">All Users</h5>
                            </div>
                            <div class="col-md-6 text-right">
                                @Html.ActionLink("Create New User", "Create", "User", null, new { @class = "btn btn-primary btn-sm waves-effect waves-light", @id = "btnCreate" })
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table id="userTable"
                                   data-toggle="table"
                                   data-search="true"
                                   data-show-columns="true"
                                   data-pagination="true"
                                   data-page-size="10"
                                   data-search-align="left"
                                   class="table table-bordered dt-responsive nowrap table-hover"
                                   style="width: 100%;">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 60px;">SL.</th>
                                        <th data-field="userName" data-sortable="true">User Name</th>
                                        <th data-field="email" data-sortable="true">Email</th>
                                        <th data-field="phone" data-sortable="true">Phone</th>
                                        <th data-field="status" data-sortable="true">Status</th>
                                        <th class="text-center" style="width: 120px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@count</td>
                                                <td><strong>@item.UserName</strong></td>
                                                <td>@item.Email</td>
                                                <td>@item.PhoneNumber</td>
                                                <td>
                                                    @if (item.Status == "Active")
                                                    {
                                                        <span class="badge badge-soft-success font-size-12">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-soft-danger font-size-12">@item.Status</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <div class="btn-group" role="group">
                                                        <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Edit", new { id = item.Id })" title="Edit">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </a>

                                                        @if (item.Status == "Active")
                                                        {
                                                            <a href="@Url.Action("ChangeStatus", new { id = item.Id, status = "0" })"
                                                               class="btn btn-outline-warning btn-sm" title="Inactive"
                                                               onclick="return confirm('Do you want to inactive this user?')">
                                                                <i class="mdi mdi-account-off-outline"></i>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("ChangeStatus", new { id = item.Id, status = "1" })"
                                                               class="btn btn-outline-success btn-sm" title="Active"
                                                               onclick="return confirm('Do you want to active this user?')">
                                                                <i class="mdi mdi-account-check-outline"></i>
                                                            </a>
                                                        }

                                                        <a class="btn btn-outline-danger btn-sm" href="@Url.Action("Delete", new { id = item.Id })"
                                                           title="Delete" onclick="return confirm('Do you want to delete this user?');">
                                                            <i class="mdi mdi-delete-outline"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            count++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @* Bootstrap Table CSS and JS (Company Formatted CDN) *@
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>

    <script>
        $(function () {
            // নিশ্চিত করা যে টেবিলটি বুটস্ট্র্যাপ টেবিল হিসেবে ইনিশিয়ালাইজ হয়েছে
            $('#userTable').bootstrapTable();
        });
    </script>
}