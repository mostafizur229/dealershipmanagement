@{
    Layout = null;
}

<!-- Professional Modal for Document/Invoice Viewer -->
<div class="modal fade" id="reportViewerModal" tabindex="-1" role="dialog" aria-labelledby="reportViewerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">

            <!-- Modal Header -->
            <div class="modal-header border-bottom-0 py-2" style="background: linear-gradient(90deg, #6278fe1a, #6278fe0a);">
                <h5 class="modal-title" id="reportViewerModalLabel" style="font-weight: 500; font-size: 16px; color: #343a40;">
                    Document / Invoice Viewer
                </h5>
                <button type="button" class="close text-dark" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body p-3" style="background-color: #ffffff;">
                <div class="embed-responsive" style="position: relative; width: 100%; height: 75vh; min-height: 550px;">
                    <iframe id="f1"
                            class="w-100 h-100 border-0"
                            src="/Report/RenderReport"
                            style="background: #fff; border-radius: 4px; box-shadow: 0 0 10px rgba(0,0,0,0.05);">
                    </iframe>
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="modal-footer bg-light border-top-0 py-2">
                <button type="button" class="btn btn-secondary btn-sm px-4" data-dismiss="modal">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        $('#reportViewerModal').modal({
            backdrop: 'static',
            keyboard: true
        }).modal('show');
    });
</script>

<style>
    /* Modal Dialog Centered */
    .modal-dialog-centered {
        display: flex;
        align-items: center;
        min-height: calc(100% - 3.5rem);
    }

    /* Buttons in Footer */
    .modal-footer .btn {
        min-width: 80px;
        margin-left: 5px;
    }

    .btn-secondary {
        background-color: #f1f3f5;
        color: #495057;
        border: none;
    }

        .btn-secondary:hover {
            background-color: #e2e6ea;
        }
</style>