@model IEnumerable<ProductUnitTypeViewModel>
@{
    ViewBag.Title = "Product Units";
    int count = 1;
}

<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">@ViewBag.Title</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item active">Manage Existing @ViewBag.Title</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h5 class="header-title">Existing @ViewBag.Title</h5>
                            </div>
                            <div class="col-md-6 text-right">
                                @Html.ActionLink("Create New Unit", "Create", "ProductUnit", null, new { @class = "btn btn-primary btn-sm", @id = "btnCreate" })
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table id="unitTable"
                                   data-toggle="table"
                                   data-search="true"
                                   data-show-columns="true"
                                   data-pagination="true"
                                   data-page-size="10"
                                   data-search-align="left"
                                   class="table table-bordered dt-responsive nowrap table-hover"
                                   style="width: 100%;">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 50px;">SL.</th>
                                        <th data-field="description" data-sortable="true">@Html.DisplayNameFor(model => model.Description)</th>
                                        <th data-field="convertValue" data-sortable="true">@Html.DisplayNameFor(model => model.ConvertValue)</th>
                                        <th data-field="unitName" data-sortable="true">@Html.DisplayNameFor(model => model.UnitName)</th>
                                        <th data-field="position" data-sortable="true">@Html.DisplayNameFor(model => model.Position)</th>
                                        <th data-field="status" data-sortable="true" class="text-center">@Html.DisplayNameFor(model => model.Status)</th>
                                        <th class="text-center" style="width: 150px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@count</td>
                                                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                                                <td>@Html.DisplayFor(modelItem => item.ConvertValue)</td>
                                                <td>@Html.DisplayFor(modelItem => item.UnitName)</td>
                                                <td>@Html.DisplayFor(modelItem => item.Position)</td>
                                                <td class="text-center">
                                                    @if (item.Status == 1)
                                                    {
                                                        <span class="badge badge-soft-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-soft-danger">Inactive</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <div class="btn-group" role="group">
                                                        @if (item.Status == 1)
                                                        {
                                                            <a class="btn btn-outline-warning btn-sm" href="@Url.Action("Inactive", "ProductUnit", new { id = item.ProUnitTypeID })" title="Make Inactive">
                                                                <i class="mdi mdi-eye-off"></i>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a class="btn btn-outline-success btn-sm" href="@Url.Action("Active", "ProductUnit", new { id = item.ProUnitTypeID })" title="Make Active">
                                                                <i class="mdi mdi-eye"></i>
                                                            </a>
                                                        }

                                                        @if (User.IsInRole("Admin"))
                                                        {
                                                            <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Edit", "ProductUnit", new { id = item.ProUnitTypeID })" title="Edit">
                                                                <i class="mdi mdi-pencil"></i>
                                                            </a>
                                                            <a class="btn btn-outline-danger btn-sm" href="@Url.Action("Delete", "ProductUnit", new { id = item.ProUnitTypeID })"
                                                               title="Delete" onclick="return confirm('Do you want to delete this unit?');">
                                                                <i class="mdi mdi-delete"></i>
                                                            </a>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                            count++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>
}