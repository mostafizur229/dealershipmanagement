@model IEnumerable<IMSWEB.CreateSisterConcernViewModel>
@{
    ViewBag.Title = "Sister Concern";
    int count = 1;
}

<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">Sister Concerns</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item active">Manage Existing Sister Concerns</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h5 class="header-title">Sister Concern List</h5>
                            </div>
                            <div class="col-md-6 text-right">
                                @Html.ActionLink("Create New Sister Concern", "Create", "SisterConcern", null, new { @class = "btn btn-primary btn-sm waves-effect waves-light", @id = "btnCreate" })
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table id="SisterConcernTable"
                                   data-toggle="table"
                                   data-search="true"
                                   data-show-columns="true"
                                   data-pagination="true"
                                   data-page-size="10"
                                   data-search-align="left"
                                   class="table table-bordered dt-responsive nowrap table-hover"
                                   style="width: 100%;">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 60px;">SL.</th>
                                        <th data-field="name" data-sortable="true">Name</th>
                                        <th data-field="address" data-sortable="true">Address</th>
                                        <th data-field="contactNo" data-sortable="true">Contact No</th>
                                        <th class="text-center" style="width: 120px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@count</td>
                                                <td><strong>@item.Name</strong></td>
                                                <td>@item.Address</td>
                                                <td>@item.ContactNo</td>
                                                <td class="text-center">
                                                    <div class="btn-group" role="group">
                                                        <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Edit", new { id = item.Id })" title="Edit">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </a>
                                                        <a class="btn btn-outline-danger btn-sm" href="@Url.Action("Delete", new { id = item.Id })"
                                                           title="Delete" onclick="return confirm('Do you want to delete this sister concern?');">
                                                            <i class="mdi mdi-delete-outline"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            count++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @* Bootstrap Table CSS and JS (Company Format) *@
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>

    <script>
        $(function () {
            $('#SisterConcernTable').bootstrapTable();
        });
    </script>
}