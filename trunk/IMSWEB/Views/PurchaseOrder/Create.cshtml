@using IMSWEB.Model
@model PurchaseOrderViewModel

@{
    string actionName = ViewContext.RouteData.Values["action"].ToString();
    ViewBag.Title = actionName + " Purchase Order";
}

<style>
    /* Professional Layout Adjustments */
    .col-md-4 {
        padding-right: 0px !important;
    }

    .col-md-8 {
        padding-left: 0px !important;
    }

    .form-horizontal .control-label {
        text-align: left;
        font-weight: bold;
    }

    .fix-width-picker {
        padding-right: 5px !important;
    }

    .btn-action-align {
        padding-left: 5px !important;
        margin-top: 2px;
    }

    /* Custom Dropdown Wrapper */
    .dropdown-wrapper {
        position: relative;
        width: 100%;
        display: block;
    }

    .custom-dropdown {
        background-color: #fff;
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 6px 12px;
        height: 34px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: inset 0 1px 1px rgba(0,0,0,.075);
    }

        .custom-dropdown:hover {
            border-color: #66afe9;
        }

    /* Dropdown List Management */
    .dropdown-list {
        position: absolute;
        top: 100%;
        left: 0;
        z-index: 2000;
        display: none;
        float: left;
        min-width: 100%;
        padding: 5px 0;
        margin: 2px 0 0;
        font-size: 14px;
        text-align: left;
        background-color: #fff;
        border: 1px solid rgba(0,0,0,.15);
        border-radius: 4px;
        box-shadow: 0 6px 12px rgba(0,0,0,.175);
    }

    .search-box {
        padding: 8px;
        border-bottom: 1px solid #ddd;
    }

        .search-box input {
            height: 30px;
            padding: 5px 10px;
            font-size: 12px;
            line-height: 1.5;
            border-radius: 3px;
            border: 1px solid #ccc;
            width: 100%;
        }

    #dropdownItems, #productDropdownItems {
        max-height: 200px;
        overflow-y: auto;
    }

    .dropdown-item {
        padding: 10px 15px;
        cursor: pointer;
        border-bottom: 1px solid #eee;
    }

        .dropdown-item:hover {
            background-color: #f5f5f5;
        }

    .dropdown-trigger-icon {
        color: #555;
        font-size: 12px;
    }

    /* Modal Controls & Select2 Custom Overrides */
    #newProductAddModal .modal-content {
        border-radius: 8px;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    #newProductAddModal .modal-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid #eee;
        border-radius: 8px 8px 0 0;
        padding: 15px 25px;
    }

    #newProductAddModal .modal-title {
        font-weight: 600;
        color: #333;
        font-size: 18px;
    }

    #newProductAddModal .form-group {
        margin-bottom: 18px;
    }

    .input-group .btn-info {
        height: 30px;
        border-radius: 0 4px 4px 0;
    }

    .form-control:focus {
        border-color: #5bc0de;
        box-shadow: none;
        outline: 0;
    }

    .ui-autocomplete {
        z-index: 99999999 !important;
        max-height: 200px;
        overflow-y: auto;
        background-color: #fff;
        border: 1px solid #ccc;
    }

    .select2-container--default .select2-selection--single {
        height: 30px !important;
        padding: 3px 6px !important;
        border: 1px solid #ccc !important;
    }

    .select2-container {
        z-index: 99999 !important;
        width: 100% !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 28px !important;
    }

    #productDropdownList {
        position: absolute;
        top: 100%;
        left: 0;
        z-index: 2100;
        display: none;
        width: 100%;
        background-color: #fff;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-shadow: 0 6px 12px rgba(0,0,0,.175);
    }
</style>


<!-- Top Breadcrumb Section Box -->
<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">@actionName Purchase Order</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "PurchaseOrder")">Purchase Orders</a></li>
                    <li class="breadcrumb-item active">@actionName</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        @using (Html.BeginForm(actionName, "PurchaseOrder", new { ReturnUrl = ViewBag.ReturnUrl, IsDO = false }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.PODetail.GodownID)
            @Html.HiddenFor(m => m.PODetail.ColorId)
            @Html.HiddenFor(m => m.PODetail.PPOffer)
            @Html.HiddenFor(m => m.PurchaseOrder.IsDamagePO)

            <div class="row">
                <!-- Left Block: Purchase Entry Form -->
                <div class="col-md-6">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-transparent border-bottom">
                            <h5 class="header-title mb-0"><i class="mdi mdi-cart-plus mr-2 text-primary"></i>Purchase Order Entry</h5>
                        </div>
                        <div class="card-body">
                            <!-- Supplier Section -->
                            <div class="form-group row mb-3">
                                @Html.LabelFor(m => m.PurchaseOrder.SupplierId, new { @class = "col-md-3 col-form-label font-weight-bold" })
                                <div class="col-md-6">
                                    <div class="full-width-picker shadow-sm rounded">
                                        @{Html.RenderAction("RenderPicker", "Picker", new { pickerType = PickerType.SupplierNew, id = (Model != null && !string.IsNullOrEmpty(Model.PurchaseOrder.SupplierId)) ? Model.PurchaseOrder.SupplierId : "0" });}
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <button type="button" class="btn btn-primary btn-sm btn-block h-100" data-toggle="modal" data-target="#SuppliersModal">
                                        <i class="mdi mdi-plus-circle mr-1"></i> Add Supplier
                                    </button>
                                </div>
                            </div>

                            <!-- Product Section -->
                            <div class="form-group row mb-4">
                                @Html.LabelFor(m => m.PODetail.ProductId, new { @class = "col-md-3 col-form-label font-weight-bold" })
                                <div class="col-md-6">
                                    <div class="full-width-picker shadow-sm rounded">
                                        @{Html.RenderAction("RenderPicker", "Picker", new { pickerType = PickerType.ProductNew, id = (Model != null && !string.IsNullOrEmpty(Model.PODetail.ProductId)) ? Model.PODetail.ProductId : "0" });}
                                    </div>
                                    @Html.ValidationMessageFor(m => m.PODetail.ProductId, "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-3">
                                    <button id="btnAddProduct" type="button" class="btn btn-info btn-sm btn-block h-100 text-white">
                                        <i class="mdi mdi-package-variant-plus mr-1"></i> Add Product
                                    </button>
                                </div>
                            </div>

                            <hr class="my-4" />

                            <!-- Quantity & Rate Section -->
                            <div class="row">
                                <div class="col-md-6 border-right">
                                    <div class="form-group mb-3">
                                        @Html.LabelFor(m => m.PODetail.ParentQuantity, new { @class = "small font-weight-bold text-muted", id = "lblParentUnit" })
                                        @Html.EditorFor(m => m.PODetail.ParentQuantity, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01", tabindex = 1, placeholder = "0.00" } })
                                        @Html.ValidationMessageFor(m => m.PODetail.ParentQuantity, "", new { @class = "text-danger small" })
                                    </div>

                                    <div id="divChildQuantity" style="display:none" class="form-group mb-3">
                                        @Html.LabelFor(m => m.PODetail.ChildQuantity, new { @class = "small font-weight-bold text-muted", id = "lblChildUnit" })
                                        @Html.EditorFor(m => m.PODetail.ChildQuantity, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01", tabindex = 1, placeholder = "0.00" } })
                                        @Html.ValidationMessageFor(m => m.PODetail.ChildQuantity, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="form-group mb-3">
                                        @Html.LabelFor(m => m.PODetail.MRPRateParent, new { @class = "small font-weight-bold text-muted", id = "lblMRPParent" })
                                        @Html.EditorFor(m => m.PODetail.MRPRateParent, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01", tabindex = 2, placeholder = "0.00" } })
                                        @Html.ValidationMessageFor(m => m.PODetail.MRPRateParent, "", new { @class = "text-danger small" })
                                    </div>

                                    <div style="display:none">
                                        <div class="form-group" id="divUnitPrice">
                                            @Html.LabelFor(m => m.PODetail.MRPRate, new { @class = "small font-weight-bold", id = "lblMRP" })
                                            @Html.EditorFor(m => m.PODetail.MRPRate, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01" } })
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        @Html.LabelFor(m => m.PODetail.SalesRate, new { @class = "small font-weight-bold text-muted" })
                                        @Html.EditorFor(m => m.PODetail.SalesRate, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01", tabindex = 6, placeholder = "0.00" } })
                                        @Html.ValidationMessageFor(m => m.PODetail.SalesRate, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="form-group mb-4">
                                        @Html.LabelFor(m => m.PODetail.TAmount, new { @class = "small font-weight-bold text-primary" })
                                        @Html.EditorFor(m => m.PODetail.TAmount, new { htmlAttributes = new { @class = "form-control form-control-sm text-right bg-light font-weight-bold", type = "number", step = "0.01", @readonly = "readonly" } })
                                    </div>

                                    <!-- Hidden Fields -->
                                    <div style="display:none">
                                        @Html.EditorFor(m => m.PODetail.UnitType)
                                        @Html.EditorFor(m => m.PODetail.TempChildUnitType)
                                        @Html.EditorFor(m => m.PODetail.Quantity)
                                        @Html.EditorFor(m => m.PODetail.SizeName)
                                    </div>

                                    <div class="text-right pt-2">
                                        <button type="submit" name="addButton" value="Add to order" class="btn btn-success btn-sm px-4 shadow">
                                            <i class="mdi mdi-plus-box mr-1"></i> Add to List
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Block: Order Info & Metadata -->
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 mb-3">
                        <div class="card-header bg-soft-primary border-bottom-0">
                            <h5 class="header-title mb-0 font-size-14 text-primary">
                                <i class="mdi mdi-information-outline mr-1"></i> Order Information
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 border-right">
                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PurchaseOrder.CurrentDue, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.CurrentDue, new { htmlAttributes = new { @class = "form-control form-control-sm text-right bg-soft-danger font-weight-bold text-danger", @readonly = "readonly" } })
                                    </div>

                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PODetail.UnitPrice, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.HiddenFor(m => m.PODetail.UnitPrice)
                                        <input type="number" name="tmpUnitPrice" id="tmpUnitPrice" class="form-control form-control-sm text-right bg-light" readonly />
                                    </div>

                                    <div class="form-group mb-0">
                                        @Html.LabelFor(m => m.PurchaseOrder.GrandTotal, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.GrandTotal, new { htmlAttributes = new { @class = "form-control form-control-sm text-right font-weight-bold bg-soft-primary text-primary", @readonly = "readonly" } })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PurchaseOrder.ChallanNo, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.ChallanNo, new { htmlAttributes = new { @class = "form-control form-control-sm", placeholder = "Enter Challan No" } })
                                        @Html.ValidationMessageFor(m => m.PurchaseOrder.ChallanNo, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PurchaseOrder.OrderDate, new { @class = "small font-weight-bold text-muted mb-1" })
                                        <div class="input-group input-group-sm date-picker" id="OrderDateContainer">
                                            <input type='text' class="form-control" name='PurchaseOrder.OrderDate' id="OrderDate" />
                                            <div class="input-group-append">
                                                <span class="input-group-text"><i class="mdi mdi-calendar-month"></i></span>
                                            </div>
                                        </div>
                                        @Html.ValidationMessageFor(m => m.PurchaseOrder.OrderDate, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="form-group mb-0">
                                        @Html.LabelFor(m => m.PurchaseOrder.TotalAmount, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.TotalAmount, new { htmlAttributes = new { @class = "form-control form-control-sm text-right bg-light font-weight-bold", @readonly = "readonly" } })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-soft-info border-bottom-0">
                            <h5 class="header-title mb-0 font-size-14 text-info">
                                <i class="mdi mdi-warehouse mr-1"></i> Storage & Area
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="form-group mb-3">
                                @Html.LabelFor(m => m.PODetail.GodownID, new { @class = "small font-weight-bold text-muted mb-1" })
                                <div class="shadow-sm rounded">
                                    @{Html.RenderAction("RenderPicker", "Picker", new { pickerType = PickerType.Godown, id = (Model != null && !string.IsNullOrEmpty(Model.PODetail.GodownID)) ? Model.PODetail.GodownID : "0" });}
                                </div>
                                @Html.ValidationMessageFor(m => m.PODetail.GodownID, "", new { @class = "text-danger small" })
                            </div>

                            <div class="row">
                                <div class="col-md-6" id="RatePerAreadiv" style="display:none">
                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PODetail.RatePerArea, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PODetail.RatePerArea, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01", tabindex = 2 } })
                                    </div>
                                </div>
                                <div class="col-md-6" id="divUnitPrice" style="display:none">
                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PODetail.MRPRate, new { @class = "small font-weight-bold text-muted mb-1", id = "lblMRP" })
                                        @Html.EditorFor(m => m.PODetail.MRPRate, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01", tabindex = 2 } })
                                    </div>
                                </div>
                                <div class="col-md-6" id="TotalAreadiv" style="display:none">
                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PODetail.TotalArea, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PODetail.TotalArea, new { htmlAttributes = new { @class = "form-control form-control-sm text-right bg-light", type = "number", step = "0.01", @readonly = "readonly" } })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-2" style="display:none">
                                        @Html.LabelFor(m => m.PODetail.ConvertValue, new { @class = "small font-weight-bold text-muted mb-1", id = "lblConvertValue" })
                                        @Html.EditorFor(m => m.PODetail.ConvertValue, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", @readonly = "readonly" } })
                                    </div>
                                </div>
                            </div>

                            <div style="display: none">
                                @Html.LabelFor(m => m.PODetail.Category, new { @class = "control-label", id = "lblSize" })
                                @Html.EditorFor(m => m.PODetail.Category, new { htmlAttributes = new { @class = "form-control text-right", @readonly = "readonly" } })
                            </div>

                            <div class="alert bg-soft-info border-0 mb-0 mt-2 p-2">
                                <p class="mb-0 small text-info"><i class="mdi mdi-alert-circle-outline mr-1"></i> Additional details are automatically calculated based on selection.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Lower Section: Table List & Payment Summary -->
            <div class="row mt-4">
                <div class="col-xl-7">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-transparent border-bottom">
                            <h5 class="header-title mb-0">
                                <i class="mdi mdi-format-list-bulleted mr-1 text-primary"></i> Order Items
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table id="productTable"
                                       data-toggle="table"
                                       data-search="true"
                                       data-search-align="left"
                                       data-height="300"
                                       class="table table-centered table-nowrap mb-0 table-hover table-bordered">
                                    <thead class="thead-light">
                                        <tr>
                                            <th style="width: 50px;">Sl</th>
                                            <th>@Html.DisplayNameFor(model => model.PODetail.ProductName)</th>
                                            <th>@Html.DisplayNameFor(model => model.PODetail.Category)</th>
                                            <th>Unit</th>
                                            <th>Size</th>
                                            <th class="text-right">Qty</th>
                                            <th class="text-right">Rate</th>
                                            <th class="text-right">Total</th>
                                            <th class="text-center" style="width: 90px;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            int c = 1;
                                            foreach (var item in Model.PODetails)
                                            {
                                                if (item.Status == EnumStatus.Updated || item.Status == EnumStatus.Deleted) { continue; }
                                                var qty = Math.Round((Convert.ToDecimal(item.Quantity) / Convert.ToDecimal(item.ConvertValue)), 2);
                                                var unitPrice = Math.Round((Convert.ToDecimal(item.UnitPrice) * Convert.ToDecimal(item.ConvertValue)), 2);

                                                <tr>
                                                    <td>@c</td>
                                                    <td class="font-weight-bold">@item.ProductName</td>
                                                    <td><span class="badge badge-soft-info">@item.Category</span></td>
                                                    <td>@item.UnitType</td>
                                                    <td>@item.SizeName</td>
                                                    <td class="text-right">@qty</td>
                                                    <td class="text-right">@unitPrice</td>
                                                    <td class="text-right font-weight-bold text-primary">@item.TAmount</td>
                                                    <td class="text-center">
                                                        <div class="btn-group">
                                                            <a href="@Url.Action("EditFromView", "PurchaseOrder", new { id = item.ProductId, cid = item.ColorId, previousAction = actionName.ToLower(), IsDO = false })" class="btn btn-outline-info btn-sm">
                                                                <i class="mdi mdi-pencil"></i>
                                                            </a>
                                                            <a href="@Url.Action("DeleteFromView", "PurchaseOrder", new { id = item.ProductId, cid = item.ColorId, previousAction = actionName.ToLower(), IsDO = false })" class="btn btn-outline-danger btn-sm" onclick="return confirm('Do you want to delete this item?');">
                                                                <i class="mdi mdi-trash-can"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                                c++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-5">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-soft-primary border-bottom-0">
                            <h5 class="header-title mb-0 text-primary">
                                <i class="mdi mdi-calculator mr-1"></i> Payment Summary
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 border-right">
                                    <div class="form-group mb-2 totalDiscountPercentage">
                                        @Html.LabelFor(m => m.PurchaseOrder.TotalDiscountPercentage, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.TotalDiscountPercentage, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01" } })
                                        @Html.HiddenFor(m => m.PurchaseOrder.PPDiscountAmount)
                                    </div>

                                    <div class="form-group mb-2 totalDiscountAmount">
                                        @Html.LabelFor(m => m.PurchaseOrder.TotalDiscountAmount, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.TotalDiscountAmount, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01" } })
                                        @Html.HiddenFor(m => m.PurchaseOrder.tempFlatDiscountAmount)
                                    </div>

                                    <div class="form-group mb-2">
                                        @Html.LabelFor(m => m.PurchaseOrder.RecieveAmount, new { @class = "small font-weight-bold text-success mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.RecieveAmount, new { htmlAttributes = new { @class = "form-control form-control-sm text-right border-success", type = "number", step = "0.01" } })
                                    </div>

                                    <div class="form-group mb-0 remarks">
                                        @Html.LabelFor(m => m.PurchaseOrder.Remarks, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.Remarks, new { htmlAttributes = new { @class = "form-control form-control-sm", placeholder = "Notes..." } })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group mb-2 adjAmount">
                                        @Html.LabelFor(m => m.PurchaseOrder.AdjAmount, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.AdjAmount, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01" } })
                                    </div>

                                    <div class="form-group mb-2 netDiscount">
                                        @Html.LabelFor(m => m.PurchaseOrder.NetDiscount, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.NetDiscount, new { htmlAttributes = new { @class = "form-control form-control-sm text-right bg-light", @readonly = "readonly" } })
                                        @Html.HiddenFor(m => m.PurchaseOrder.tempNetDiscount)
                                    </div>

                                    <div class="form-group mb-2 PaymentDue">
                                        @Html.LabelFor(m => m.PurchaseOrder.PaymentDue, new { @class = "small font-weight-bold text-danger mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.PaymentDue, new { htmlAttributes = new { @class = "form-control form-control-sm text-right bg-soft-danger font-weight-bold text-danger", @readonly = "readonly" } })
                                    </div>

                                    <div class="form-group mb-3 LabourCost">
                                        @Html.LabelFor(m => m.PurchaseOrder.LabourCost, new { @class = "small font-weight-bold text-muted mb-1" })
                                        @Html.EditorFor(m => m.PurchaseOrder.LabourCost, new { htmlAttributes = new { @class = "form-control form-control-sm text-right", type = "number", step = "0.01" } })
                                    </div>

                                    <div class="text-right">
                                        <button type="button" class="btn btn-soft-info btn-sm mr-1 shadow-sm">
                                            <i class="mdi mdi-eye-outline mr-1"></i> Preview
                                        </button>
                                        <button type="submit" name="submitButton" value="Save order" class="btn btn-primary btn-sm px-3 shadow">
                                            <i class="mdi mdi-content-save-all mr-1"></i> Save Order
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Barcode Identifiers Hidden-Row -->
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="row" style="display:none" id="imeiEntryRow">
                        <div class="col-md-12">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-soft-warning border-bottom-0">
                                    <h5 class="header-title mb-0 font-size-14 text-warning">
                                        <i class="mdi mdi-barcode-scan mr-1"></i> Product Identifiers (IMEI/Barcode)
                                    </h5>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table id="productIdentifierTable" data-toggle="table" data-height="255" class="table table-sm table-centered table-nowrap mb-0 table-hover">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th style="width: 5%">Sl</th>
                                                    <th style="width: 25%">Product Name</th>
                                                    <th style="width: 30%">IMEI / Barcode</th>
                                                    <th style="width: 30%">Damage IMEI</th>
                                                    <th style="width: 10%" class="text-center">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{
                                                    int i = 1;
                                                    if (TempData["POProductDetails"] != null)
                                                    {
                                                        foreach (var item in (List<POProductDetail>)TempData["POProductDetails"])
                                                        {
                                                            <tr>
                                                                <td>@i</td>
                                                                <td class="font-weight-medium">@Model.PODetail.ProductName</td>
                                                                <td>
                                                                    <input type="text" class="form-control form-control-sm" value="@item.IMENO" name="@("IMEINo" + i)" placeholder="Scan Barcode" />
                                                                </td>
                                                                <td>
                                                                    <input type="text" class="form-control form-control-sm bg-light" value="@item.DIMENO" name="@("DIMEINo" + i)" id="@("DIMEINo" + i)" readonly />
                                                                </td>
                                                                <td class="text-center">
                                                                    @if (Model.PurchaseOrder.IsDamagePO)
                                                                    {
                                                                        <button type="button" id="@i" class="btn btn-soft-info btn-sm btnGetDamageProduct" title="Get Damage Product">
                                                                            <i class="mdi mdi-information-outline"></i>
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <button type="button" id="@i" class="btn btn-soft-secondary btn-sm btnGetDamageProduct" title="Get Damage Product" disabled>
                                                                            <i class="mdi mdi-information-outline"></i>
                                                                        </button>
                                                                    }
                                                                </td>
                                                            </tr>
                                                            i++;
                                                        }
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-top py-2">
                                    <small class="text-muted"><i class="mdi mdi-help-circle-outline mr-1"></i> Use barcode scanner for faster entry.</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

