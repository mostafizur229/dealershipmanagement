@using IMSWEB.Model
@model IEnumerable<GetPurchaseOrderViewModel>
@{
    ViewBag.Title = "Purchase Orders";
    int count = 1;
}

<div class="page-title-box">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="page-title mb-1">@ViewBag.Title</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item active">Manage Existing Purchase Orders</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-content-wrapper">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card shadow-sm">
                    <div class="card-body">

                        @* ডেট ফিল্টার এবং ক্রিয়েট বাটন সেকশন *@
                        @using (Html.BeginForm("Index", "PurchaseOrder", FormMethod.Post, new { id = "searchForm" }))
                        {
                            <div class="row align-items-end mb-4">
                                <div class="col-md-3">
                                    <label class="font-size-13 text-muted">From Date</label>
                                    <div class="input-group date-picker-group" id="FromDateContainer">
                                        <input type="text" class="form-control form-control-sm" name="FromDate" value="@ViewBag.FromDate.ToString("dd-MMM-yyyy")" />
                                        <div class="input-group-append">
                                            <span class="input-group-text"><i class="mdi mdi-calendar"></i></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label class="font-size-13 text-muted">To Date</label>
                                    <div class="input-group date-picker-group" id="ToDateContainer">
                                        <input type="text" class="form-control form-control-sm" name="ToDate" value="@ViewBag.ToDate.ToString("dd-MMM-yyyy")" />
                                        <div class="input-group-append">
                                            <span class="input-group-text"><i class="mdi mdi-calendar"></i></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 text-right">
                                    <button type="submit" class="btn btn-info btn-sm px-4 waves-effect waves-light">
                                        <i class="mdi mdi-filter-variant mr-1"></i> Filter
                                    </button>

                                    @if (!User.IsInRole(EnumUserRoles.shafique_ref.ToString()))
                                    {
                                        <a href="@Url.Action("Create")" class="btn btn-primary btn-sm px-3 waves-effect waves-light ml-1">
                                            <i class="mdi mdi-plus-circle mr-1"></i> Create New Order
                                        </a>
                                    }
                                    <img id="spinningIcon" height="30" style="display: none;" src="~/Content/images/Spinner.gif" />
                                </div>
                            </div>
                        }

                        <hr />

                        @* কোম্পানি পেজের মতো সার্চ সম্বলিত টেবিল ডিজাইন *@
                        <div class="table-responsive">
                            <table id="purchaseOrderTable"
                                   data-toggle="table"
                                   data-search="true"
                                   data-show-columns="true"
                                   data-pagination="true"
                                   data-page-size="15"
                                   data-search-align="left"
                                   class="table table-bordered dt-responsive nowrap table-hover"
                                   style="width: 100%;">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 50px;">SL.</th>
                                        <th data-field="challan" data-sortable="true">@Html.DisplayNameFor(model => model.ChallanNo)</th>
                                        <th data-field="date" data-sortable="true">@Html.DisplayNameFor(model => model.OrderDate)</th>
                                        <th data-field="supplier" data-sortable="true">@Html.DisplayNameFor(model => model.SupplierName)</th>
                                        <th data-field="company" data-sortable="true">@Html.DisplayNameFor(model => model.CompanyName)</th>
                                        <th data-field="contact" data-sortable="true">@Html.DisplayNameFor(model => model.ContactNo)</th>
                                        <th data-field="status" data-sortable="true" class="text-center">Status</th>
                                        <th class="text-center" style="width: 150px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@count</td>
                                            <td>@item.ChallanNo</td>
                                            <td>@item.OrderDate</td>
                                            <td>@item.SupplierName</td>
                                            <td>@item.CompanyName</td>
                                            <td>@item.ContactNo</td>
                                            <td class="text-center">
                                                <span class="badge @(item.Status == "Purchase" ? "badge-soft-success" : "badge-soft-warning") p-1 px-2">@item.Status</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    @if (User.IsInRole(EnumUserRoles.Admin.ToString()) || User.IsInRole(EnumUserRoles.LocalAdmin.ToString()))
                                                    {
                                                        if (item.Status.Equals("Purchase"))
                                                        {
                                                            <a href="@Url.Action("Edit", new { orderId = item.PurchaseOrderId, IsDO = false })" class="btn btn-outline-secondary btn-sm" title="Edit">
                                                                <i class="mdi mdi-pencil"></i>
                                                            </a>
                                                            <a href="@Url.Action("Delete", new { orderId = item.PurchaseOrderId, IsDO = false })" class="btn btn-outline-danger btn-sm" title="Return" onclick="return confirm('Do you want to delete this order?');">
                                                                <i class="mdi mdi-undo-variant"></i>
                                                            </a>
                                                            <a href="@Url.Action("PrintPOSInvoice", new { orderId = item.PurchaseOrderId })" class="btn btn-outline-success btn-sm" title="POS">
                                                                <i class="mdi mdi-printer-pos"></i>
                                                            </a>
                                                        }
                                                        <a href="@Url.Action("GetInvoiceByID", new { orderId = item.PurchaseOrderId, IsDO = false })" class="btn btn-outline-info btn-sm" title="Invoice">
                                                            <i class="mdi mdi-file-document-outline"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                        count++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="report"></div>

@section scripts {
    @* Bootstrap Table CSS/JS *@
    <link rel="stylesheet" href="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.css">
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>

    @* Date Picker CSS/JS *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/css/bootstrap-datetimepicker.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/js/bootstrap-datetimepicker.min.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {

            var dateOptions = {
                format: 'DD-MMM-YYYY',
                showTodayButton: true,
                allowInputToggle: true,
                icons: {
                    previous: 'mdi mdi-chevron-left',
                    next: 'mdi mdi-chevron-right'
                }
            };

            $('#FromDateContainer').datetimepicker(dateOptions);
            $('#ToDateContainer').datetimepicker(dateOptions);
       
            $('#searchForm').submit(function() {
                $('#spinningIcon').show();
            });
          
            @{
                if (TempData.ContainsKey("IsInvoiceReady") && Convert.ToBoolean(TempData["IsInvoiceReady"]))
                {
                    @:$.ajax({ url: "/Report/PurchaseInvoice", type: "GET", success: function (data) { $('#report').html(data); } });
                }
            }
        });
    </script>
}