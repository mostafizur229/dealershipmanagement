@model IEnumerable<GetProductViewModel>
@using IMSWEB.Model


<h4 class="text-left inline-header">Existing products.</h4>
<hr />
          @if (!User.IsInRole(EnumUserRoles.shafique_ref.ToString()))
           {
            @Html.ActionLink("Create new product", "Create", routeValues: null, htmlAttributes: new { @class = "btn btn-primary btn-sm pull-right", id = "toolbar" })
           }

<table id="productTable"
       data-toggle="table"
       data-search="true"
       data-trim-on-search="false"
       data-show-refresh="true"
       data-show-toggle="true"
       data-show-columns="true"
       data-show-export="true"
       data-detail-view="fasle"
       data-pagination="true"
       data-id-field="productName"
       data-page-list="[10, 25, 50, 100, ALL]"
       data-page-size="10"
       data-toolbar="#toolbar"
       class="table table-responsive table-bordered table-striped" cellspacing="0" width="100%">
    <thead>
        <tr data-height="50">
            <th>
                Sl
            </th>
            <th data-field="code"
                data-sortable="true">
                @Html.DisplayNameFor(model => model.ProductCode)
            </th>
            <th data-field="productName"
                data-sorter="sorter"
                data-sortable="true">
                @Html.DisplayNameFor(model => model.ProductName)
            </th>
            <th data-field="categoryName"
                data-sortable="true">
                @Html.DisplayNameFor(model => model.CategoryName)
            </th>
            <th data-field="companyName"
                data-sortable="true">
                @Html.DisplayNameFor(model => model.CompanyName)
            </th>
            <th data-field="SizeName"
                data-sortable="true">
                @Html.DisplayNameFor(model => model.SizeName)
            </th>
            <th data-field="RP" data-sortable="true">
                @Html.DisplayNameFor(model => model.RP)
            </th>

            <th data-field="MRP"
                data-sortable="true">
                @Html.DisplayNameFor(model => model.MRPRate)
            </th>

            @*@if (!User.IsInRole("Manager") || !User.IsInRole("Shofiq-manager"))//!(bool)ViewBag.IsEhmsOthers
                {*@
            @if (User.IsInRole(EnumUserRoles.Admin.ToString()) || User.IsInRole(EnumUserRoles.LocalAdmin.ToString()))
            {
                <th style="display:none">Update</th>
                @*}*@

            }
            @*@if (!(bool)ViewBag.IsEhmsOthers)
                {
                    <th data-width="200">Action</th>
                }*@

        </tr>
    </thead>
    <tbody>
        @{
            int count = 1;
            //var groupItems = Model.GroupBy(x => x.ProductId).Select(x => x.FirstOrDefault());
            foreach (var item in Model)
            {
                <tr>
                    <td>
                        @count
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ProductCode)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ProductName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.CategoryName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.CompanyName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.SizeName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.RP)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.MRPRate)
                    </td>
                    @*<td style="display: none">
                            <input type="button" class="btn btn-info btn-xs" title="Update Sales Rate" id="showmodalbtn" value="Update"
                                   data-productname="@item.ProductName" data-productid=@item.ProductId data-salesrate="@item.MRPRate" data-purchase="@item.RP" />
                        </td>*@

                    @*@if (!User.IsInRole("Manager") || !User.IsInRole("Shofiq-manager"))//!(bool)ViewBag.IsEhmsOthers
                        {
                            <td>

                                @Html.ActionLink("Update", "Edit", new { id = item.ProductId }) |
                                @Html.ActionLink("Delete", "Delete", new { id = item.ProductId }, new { onclick = "if(!confirm('Do you want to delete this product?')) return false;" })
                            </td>
                        }*@
                    @if (User.IsInRole(EnumUserRoles.Admin.ToString()) || User.IsInRole(EnumUserRoles.LocalAdmin.ToString()))
                    {
                        <td>

                            @Html.ActionLink("Update", "Edit", new { id = item.ProductId }) |
                            @Html.ActionLink("Delete", "Delete", new { id = item.ProductId }, new { onclick = "if(!confirm('Do you want to delete this product?')) return false;" })
                        </td>
                    }
                </tr>
                count++;
            }
        }
    </tbody>
</table>



